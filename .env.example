# Shared
NODE_ENV=development
IMAGE_REGISTRY=local
IMAGE_NAMESPACE=lutra-template
NODE_IMAGE=node:20-alpine

# Supabase infrastructure
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
KONG_ADMIN_PORT=8001
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-at-least-32-characters
JWT_EXPIRY=3600
ANON_KEY=generate-with-scripts-create-local-env
SERVICE_ROLE_KEY=generate-with-scripts-create-local-env
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me
API_EXTERNAL_URL=http://127.0.0.1:8000
SITE_URL=http://127.0.0.1:10086
ADDITIONAL_REDIRECT_URLS=http://127.0.0.1:10086
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
PGRST_DB_SCHEMAS=public,storage,graphql_public
SECRET_KEY_BASE=change-me-at-least-64-characters

# Frontend
H5_HTTP_PORT=10086
# Use https://your-domain/api when the public Nginx only exposes Kong behind /api/.
TARO_APP_API_BASE_URL=http://127.0.0.1:8000
TARO_APP_H5_BASE_URL=http://127.0.0.1:10086
TARO_APP_SUPABASE_ANON_KEY=generate-with-scripts-create-local-env

# API service
DEEPSEEK_SERVICE_URL=http://deepseek-service:3021
IMAGE_SERVICE_URL=http://image-service:3022

# DeepSeek example service
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Volcengine Ark image generation service
ARK_API_KEY=
ARK_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128

# WeChat mini program CI
WX_APPID=
WX_PRIVATE_KEY=
WX_ROBOT=1

# Test deploy
TEST_SERVER_HOST=
TEST_SERVER_USER=root
TEST_SERVER_PATH=/opt/lutra-fullstack-template/server
TEST_SSH_PRIVATE_KEY=
TEST_H5_HTTP_PORT=10086

# Production deploy
PROD_SERVER_HOST=
PROD_SERVER_USER=root
PROD_SERVER_PATH=/opt/lutra-fullstack-template/server
PROD_SSH_PRIVATE_KEY=
